# ── Copy to `.env` and fill in for local runs. In CI, these come from the
#    `e2e-aws` GitHub Environment secrets (see e2e/README.md). Use placeholder
#    values here only — never commit real tenant values. ──────────────────────

# Base domain of your deployment. Sibling hosts default to api.<base> / id.<base>.
BASE_DOMAIN=your-tenant.example.com
# Optional overrides if your DNS doesn't follow the api.<base> / id.<base> scheme:
# API_DOMAIN=api.your-tenant.example.com
# IDENTITY_DOMAIN=id.your-tenant.example.com

# Optional explicit URL overrides (otherwise derived from the domains above):
# CHAT_APP_URL=https://your-tenant.example.com/chat
# KNOWLEDGE_UPLOAD_APP_URL=https://your-tenant.example.com/knowledge-upload
# ADMIN_APP_URL=https://your-tenant.example.com/admin
# CHAT_BACKEND_API_URL=https://api.your-tenant.example.com/chat/graphql
# INGESTION_BACKEND_API_URL=https://api.your-tenant.example.com/ingestion/graphql

# Free-form environment label used in reports/logs.
TEST_ENV=AWS

# ── Identity (Zitadel / OIDC) ────────────────────────────────────────────────
# Derived from IDENTITY_DOMAIN by default; override only if it differs.
# ZITADEL_DOMAIN=https://id.your-tenant.example.com
# Zitadel project id for the Unique app (audience of issued tokens).
ZITADEL_UNIQUE_APP_PROJECT_ID=

# ── Browser test user (a normal user that logs in via the UI) ────────────────
TEST_USER=your-test-user@example.com
PASSWORD=

# ── API service user (Zitadel service account, client-credentials grant) ─────
SERVICE_USER_CLIENT_ID=
SERVICE_USER_CLIENT_SECRET=
