# ── Copy to `.env` and fill in for local runs. In CI, set these as repo
#    secrets/variables instead (see e2e/README.md). ──────────────────────────

# Base domain of your deployment. Sibling hosts default to api.<base> / id.<base>.
BASE_DOMAIN=hello.aws.unique.dev
# Optional overrides if your DNS doesn't follow the api.<base> / id.<base> scheme:
# API_DOMAIN=api.hello.aws.unique.dev
# IDENTITY_DOMAIN=id.hello.aws.unique.dev

# Optional explicit URL overrides (otherwise derived from the domains above):
# CHAT_APP_URL=https://hello.aws.unique.dev/chat
# KNOWLEDGE_UPLOAD_APP_URL=https://hello.aws.unique.dev/knowledge-upload
# ADMIN_APP_URL=https://hello.aws.unique.dev/admin
# SCOPE_MANAGEMENT_BACKEND_API_URL=https://api.hello.aws.unique.dev/scope-management/graphql
# CHAT_BACKEND_API_URL=https://api.hello.aws.unique.dev/chat/graphql
# INGESTION_BACKEND_API_URL=https://api.hello.aws.unique.dev/ingestion/graphql

# Free-form environment label used in reports/logs.
TEST_ENV=AWS

# The dedicated testing organisation/tenant slug the tests operate in.
# Create a throwaway org for this — do NOT point it at a real customer org.
TEST_ORGANISATION=watchdog

# ── Identity (Zitadel / OIDC) ────────────────────────────────────────────────
ZITADEL_DOMAIN=https://id.hello.aws.unique.dev
# Zitadel project id for the Unique app (audience of issued tokens).
ZITADEL_UNIQUE_APP_PROJECT_ID=

# ── Browser test user (a normal user that logs in via the UI) ────────────────
TEST_USER=adminuser1@watchdog-aws.com
PASSWORD=

# ── API service user (Zitadel service account, client-credentials grant) ─────
SERVICE_USER_CLIENT_ID=
SERVICE_USER_CLIENT_SECRET=
